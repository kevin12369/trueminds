{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES2022"
    ],
    "jsx": "preserve",
    "noEmit": true,
    "incremental": true,
    "types": [
      "node",
      "vitest/globals"
    ],
    "allowJs": true
  },
  "include": [
    "pages/**/*",
    "components/**/*",
    "lib/**/*",
    "tests/**/*"
  ],
  "exclude": [
    "node_modules"
  ]
}
